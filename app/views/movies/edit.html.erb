<h1>Editing: <%= @movie.title %></h1>

<%= form_with(model: @movie) do |m| %>
  <%= m.label :title %>
  <%= m.text_field :title %>
  
  <%= m.label :description %>
  <%= m.text_area :description, rows: 7 %>

  <%= m.label :rating %>
  <%= m.text_field :rating %>

  <%= m.label :released_on %>
  <%= m.date_field :released_on %>

  <%= m.label :total_gross %>
  <%= m.text_field :total_gross %>

  <%= m.submit %>
<% end %>
