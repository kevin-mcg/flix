<%= form_with(model: movie) do |m| %>
  <%= m.label :title %>
  <%= m.text_field :title, autofocus: true %>
  
  <%= m.label :description %>
  <%= m.text_area :description, rows: 10 %>

  <%= m.label :rating %>
  <%= m.text_field :rating %>

  <%= m.label :released_on %>
  <%= m.date_field :released_on %>

  <%= m.label :total_gross %>
  <%= m.text_field :total_gross %>

  <%= m.label :director %>
  <%= m.text_field :director %>

  <%= m.label :duration %>
  <%= m.text_field :duration %>

  <%= m.label :image_file_nom %>
  <%= m.text_field :image_file_name %>

  <%= m.submit %>
<% end %>
